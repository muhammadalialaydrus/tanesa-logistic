													<p data-aos="fade-in">
														Gunakan <strong>FTL (Full Truck Load)</strong> jika pengiriman Anda membutuhkan satu truk khusus tanpa digabung dengan kargo lain.
													</p>
													<p data-aos="fade-in">
														Kelebihan :
													</p>
													<ul class="list-group">
														<li>
															<span class="icon-check fa fa-check"></span>
															<p class="text-list">Volume pengiriman besar (±3 CBM ke atas).</p>
														</li>
														<li>
															<span class="icon-check fa fa-check"></span>
															<p class="text-list">Ingin satu truk khusus untuk barang Anda.</p>
														</li>
														<li>
															<span class="icon-check fa fa-check"></span>
															<p class="text-list">Barang membutuhkan penanganan lebih aman tanpa konsolidasi.</p>
														</li>
														<li>
															<span class="icon-check fa fa-check"></span>
															<p class="text-list">Pengiriman bersifat proyek atau distribusi besar.</p>
														</li>
														<li>
															<span class="icon-check fa fa-check"></span>
															<p class="text-list">Ingin proses pengiriman yang lebih stabil dan terkontrol.</p>
														</li>
													</ul>
												</div>
											</div>
										</div>
									</div>
								</div>
