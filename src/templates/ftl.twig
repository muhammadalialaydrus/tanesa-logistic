{% extends 'layouts/default.twig' %}
{% set body_class = 'ftl' %}
{% set head_title = 'Full Truck Load' %}
{% block page %}

			<div class="page-content">
				<div class="ftl-page">
					<section class="header-page">
						<div class="header-wrapper">
							<div class="container">
								<nav aria-label="breadcrumb">
									<ol class="breadcrumb">
										<li class="breadcrumb-item" data-aos="fade-in">
											<a href="index.html">
												<span class="fa fa-home"></span>
											</a>
										</li>
										<li class="breadcrumb-item" data-aos="fade-in">
											<a href="land-freight.html">
												Land Freight
											</a>
										</li>
										<li class="breadcrumb-item active" data-aos="fade-in" aria-current="page">FTL</li>
									</ol>
								</nav>
								<div class="title-cover">
									<div class="row align-items-center">
										<div class="col-md-6 order-md-last hide-mobile">
											<div class="cover-image" data-aos="zoom-in">
												<figure>
													<img src="assets/img/photos/img-landfreight.png" alt="">
												</figure>
											</div>
										</div>
										<div class="col-md-6">
											<div class="title-page">
												<h2 class="font-text-semibold" data-aos="fade-in">
													Full Truck Load
												</h2>
												<h6 data-aos="fade-in">Kami memberikan berbagai macam solusi sesuai dengan kebutuhan bisnis Anda.</h6>
											</div>
											<div class="price-check">
												<div class="check-box" data-aos="zoom-in">
													<h5 class="font-text-semibold">Cek Tarif</h5>
													<div class="custom-form">
														<form class="form">
															<div class="form-row">
																<div class="form-group col-md-12">
																	<label class="label-form font-text-semibold" for="originCityField">Kota Asal</label>
																	<input type="text" class="form-control" id="originCityField" name="originCity" placeholder="Masukkan Kota Asal..." required>
																</div>
																<div class="form-group col-md-12">
																	<label class="label-form font-text-semibold" for="destinationCityField">Kota Tujuan</label>
																	<input type="text" class="form-control" id="destinationCityField" name="destinationCity" placeholder="Masukkan Kota Tujuan..." required>
																</div>
															</div>
															<div class="button-area">
																<a href="check-rates-result-empty.html" class="button full-rounded full-width font-text-semibold">Cari</a>
																<!-- <button class="button full-rounded full-width font-text-semibold" type="submit">Cari</button> -->
															</div>
														</form>
													</div>
