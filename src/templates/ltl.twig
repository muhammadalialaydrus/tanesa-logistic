													<div class="custom-form">
														<form class="form">
															<div class="form-row">
																<div class="form-group col-md-12">
																	<label class="label-form font-text-semibold" for="originCityField">Kota Asal</label>
																	<input type="text" class="form-control" id="originCityField" name="originCity" placeholder="Masukkan Kota Asal..." required>
																</div>
																<div class="form-group col-md-12">
																	<label class="label-form font-text-semibold" for="destinationCityField">Kota Tujuan</label>
																	<input type="text" class="form-control" id="destinationCityField" name="destinationCity" placeholder="Masukkan Kota Tujuan..." required>
																</div>
															</div>
